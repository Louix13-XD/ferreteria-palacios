<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .badge-notification {
            font-size: 0.6rem !important;
            padding: 0.3em 0.5em !important;
            border: 1.5px solid #212529;
            top: -5px !important;
            right: -5px !important;
            transform: none !important;
        }
        .nav-custom-gap {
            gap: 15px;
        }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
    <!-- SweetAlert2 for Professional Notifications -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .swal2-popup { border-radius: 20px !important; font-family: 'Inter', sans-serif !important; }
        .swal2-styled.swal2-confirm { background-color: #ffc107 !important; color: #000 !important; font-weight: bold !important; border-radius: 10px !important; }
        .swal2-styled.swal2-cancel { border-radius: 10px !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center text-decoration-none" href="/">
                <img src="/img/logo_ferreteria.png" alt="Logo" class="me-3" style="width: 45px; height: 45px; object-fit: contain; border-radius: 8px;">
                <div class="d-flex flex-column justify-content-center text-center lh-1 mt-1">
                    <span class="fw-bolder text-white" style="font-size: 1.8rem; letter-spacing: 2px;">PALACIOS</span>
                    <span class="fw-normal text-light opacity-75" style="font-size: 0.75rem; letter-spacing: 5px;">FERRETERÍA</span>
                </div>
            </a>
            <!-- Buscador Central (Visible en Escritorio, colapsable en móvil) -->
            <div class="collapse navbar-collapse order-3 order-lg-2" id="navbarNav">
                <form class="d-flex mx-auto my-3 my-lg-0 position-relative" id="header-search-form" action="/search" method="GET" style="width: 100%; max-width: 500px;">
                    <div class="input-group">
                        <input class="form-control border-end-0 rounded-start-pill ps-4" type="search" name="q" id="header-search-input" placeholder="¿Qué buscas?" aria-label="Search" autocomplete="off">
                        <button class="btn btn-warning rounded-end-pill px-3 border-start-0" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                    <div id="search-suggestions" class="position-absolute top-100 start-0 w-100 bg-white shadow-lg rounded-bottom-4 overflow-hidden d-none" style="z-index: 1050; border: 1px solid #ddd; margin-top: 2px;">
                    </div>
                </form>
            </div>

            <!-- Iconos de Acción (Siempre a la derecha) -->
            <div class="d-flex align-items-center gap-2 gap-md-3 ms-auto order-2 order-lg-3">
                <div class="nav-item d-none d-sm-block" id="header-admin-btn">
                    <a class="btn btn-warning btn-sm fw-bold px-2 py-1 rounded-pill shadow-sm" href="/admin" title="Panel Administrativo">
                        <i class="bi bi-speedometer2"></i>
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link text-white p-2" href="/login" id="header-user-link">
                        <i class="bi bi-person-circle fs-4"></i>
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link text-white position-relative p-2" href="/favoritos">
                        <i class="bi bi-heart fs-4"></i>
                        <span class="position-absolute translate-middle badge rounded-pill bg-warning text-dark badge-notification" style="top: 10px; right: -2px;" id="wishlist-badge">0</span>
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link text-white position-relative p-2" href="/carrito">
                        <i class="bi bi-cart fs-4"></i>
                        <span class="position-absolute translate-middle badge rounded-pill bg-danger badge-notification" style="top: 10px; right: -2px;" id="cart-badge">0</span>
                    </a>
                </div>
                <div class="nav-item">
                    <button class="btn btn-outline-warning border-0 p-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasRight">
                        <i class="bi bi-list fs-3"></i>
                    </button>
                </div>
                <button class="navbar-toggler border-0 ms-1 p-1 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon" style="width: 1.1em; height: 1.1em;"></span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Panel Lateral (Offcanvas) -->
    <div class="offcanvas offcanvas-end bg-dark text-light" tabindex="-1" id="offcanvasRight" aria-labelledby="offcanvasRightLabel">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title fw-bold" id="offcanvasRightLabel">MENÚ PALACIOS</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <!-- Sección de Categorías -->
            <h6 class="text-uppercase text-secondary small fw-bold mb-3">Categorías</h6>
            <div class="list-group list-group-flush custom-list mb-4">
                <a href="/productos/herramientas" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-hammer me-3 text-warning"></i> Herramientas
                </a>
                <a href="/productos/pintura" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-droplet-fill me-3 text-warning"></i> Pintura
                </a>
                <a href="/productos/electricidad" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-lightning-fill me-3 text-warning"></i> Electricidad
                </a>
                <a href="/productos/plomeria" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-water me-3 text-warning"></i> Plomería
                </a>
                <a href="/productos/construccion" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-bricks me-3 text-warning"></i> Construcción
                </a>
                <a href="/productos/jardineria" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-tree-fill me-3 text-warning"></i> Jardinería
                </a>
            </div>

            <!-- Sección de Información -->
            <h6 class="text-uppercase text-secondary small fw-bold mb-3 border-top pt-3">Información</h6>
            <div class="list-group list-group-flush custom-list mb-4">
                <a href="#" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2" data-bs-toggle="modal" data-bs-target="#modalSobreNosotros">
                    <i class="bi bi-info-circle me-3 text-warning"></i> Sobre Nosotros
                </a>
                <a href="#" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2" data-bs-toggle="modal" data-bs-target="#modalContacto">
                    <i class="bi bi-envelope me-3 text-warning"></i> Contáctanos
                </a>
            </div>

            <!-- Sección de Mi Cuenta -->
            <h6 class="text-uppercase text-secondary small fw-bold mb-3 border-top pt-3">Mi Cuenta</h6>
            <div class="list-group list-group-flush custom-list">
                <a href="/admin" id="admin-panel-link" class="list-group-item list-group-item-action bg-transparent text-warning border-0 py-2 d-none">
                    <i class="bi bi-speedometer2 me-3"></i> Panel Administrativo
                </a>
                <a href="/perfil" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-person-gear me-3 text-warning"></i> Mi Perfil
                </a>
                <a href="/historial" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-2">
                    <i class="bi bi-bag-check me-3 text-warning"></i> Mi Historial de Compras
                </a>
                <a href="javascript:void(0)" onclick="logoutHeader()" class="list-group-item list-group-item-action bg-transparent text-danger border-0 py-2 mt-2">
                    <i class="bi bi-box-arrow-right me-3"></i> Cerrar Sesión
                </a>
            </div>
            
            <div class="mt-5 p-3 text-center small text-secondary border-top border-secondary">
                <p>Abierto: Lun - Sáb: 8:00 AM - 7:00 PM</p>
                <div class="social-links">
                    <i class="bi bi-facebook me-3 fs-5"></i>
                    <i class="bi bi-instagram me-3 fs-5"></i>
                    <i class="bi bi-tiktok fs-5"></i>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const user = JSON.parse(localStorage.getItem('currentUser'));
            const userLink = document.getElementById('header-user-link');
            const adminLink = document.getElementById('admin-panel-link');
            const headerAdminBtn = document.getElementById('header-admin-btn');
            
            // Si hay usuario en localStorage, verificamos que la página no sea Login
            if (user && userLink) {
                if (window.location.pathname === '/login') {
                    localStorage.removeItem('currentUser');
                    return;
                }
                
                userLink.href = '/perfil';
                userLink.innerHTML = `<i class="bi bi-person-check-fill fs-5 text-warning" title="${user.name}"></i>`;
                
                // Mostrar panel administrativo si no es cliente
                if (user.role !== 'client' && user.role !== 'Cliente') {
                    if (adminLink) adminLink.classList.remove('d-none');
                    if (headerAdminBtn) headerAdminBtn.classList.remove('d-none');
                }
            }
        });

        function logoutHeader() {
            if(confirm('¿Estás seguro de que deseas cerrar sesión?')) {
                localStorage.removeItem('currentUser');
                window.location.href = '/';
            }
        }
    </script>
