<%- include('header') %>

<main class="container mt-4">
    <!-- Hero Section -->
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1581244277943-fe4a9c777189?auto=format&fit=crop&w=1200&q=80'); background-size: cover; background-position: center;">
        <div class="container-fluid py-5 text-white">
            <h1 class="display-5 fw-bold">Calidad que Construye</h1>
            <p class="col-md-8 fs-4">Las mejores marcas y herramientas para tus proyectos grandes y pequeños.</p>
            <button class="btn btn-warning btn-lg fw-bold" type="button">Ver Catálogo</button>
        </div>
    </div>

    <!-- Categories Section -->
    <section class="row text-center mb-5">
        <div class="col-md-12 mb-4">
            <h2 class="fw-bold">Nuestras Categorías</h2>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/herramientas" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-hammer fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Herramientas</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/pintura" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-droplet-fill fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Pintura</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/electricidad" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-lightning-fill fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Electricidad</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/plomeria" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-water fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Plomería</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/construccion" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-bricks fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Construcción</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/jardineria" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-tree-fill fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Jardinería</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <a href="/productos/fijaciones" class="text-decoration-none text-dark">
                <div class="category-card p-3 border rounded shadow-sm hover-effect">
                    <i class="bi bi-nut fs-1 text-warning"></i>
                    <p class="mt-2 fw-semibold">Fijaciones y Anclajes</p>
                </div>
            </a>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold m-0">Productos Destacados</h2>
            <a href="#" class="text-warning fw-bold text-decoration-none">Ver todos <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row row-cols-1 row-cols-md-4 g-4" id="featured-products">
            <!-- Los productos se cargarán dinámicamente con JS para demostrar Manipulación del DOM -->
            <div class="col text-center py-5 w-100">
                <div class="spinner-border text-warning" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('footer') %>
