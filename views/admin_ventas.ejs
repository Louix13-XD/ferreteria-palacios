<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { background-color: #f0f2f5; font-family: 'Inter', sans-serif; }
        .admin-sidebar { width: 250px; height: 100vh; position: fixed; background: #212529; color: white; }
        .admin-content { margin-left: 250px; padding: 30px; }
        .nav-link-admin { color: rgba(255,255,255,0.7); padding: 15px 25px; display: block; text-decoration: none; border-left: 4px solid transparent; }
        .nav-link-admin:hover, .nav-link-admin.active { color: #ffc107; background: rgba(255,193,7,0.1); border-left-color: #ffc107; }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
</head>
<body>

    <%- include('admin_sidebar') %>

    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Gestión de Ventas</h2>

        </div>

        <!-- Buscador Rápido Operativo -->
        <div class="card border-0 bg-dark shadow-lg rounded-4 p-4 mb-5 text-white">
            <div class="row align-items-center">
                <div class="col-md-5">
                    <h5 class="fw-bold mb-1 text-warning"><i class="bi bi-search me-2"></i>Buscador de Boleta</h5>
                    <p class="mb-0 small opacity-75">Escribe el código para revisar los detalles y productos de la boleta.</p>
                </div>
                <div class="col-md-7">
                    <div class="input-group input-group-lg shadow-sm">
                        <input type="text" id="dispatch-search" class="form-control border-0 bg-white" placeholder="Ej: 8957">
                        <button class="btn btn-warning fw-bold px-4">BUSCAR</button>
                    </div>
                    <div id="search-result" class="mt-3 d-none">
                        <!-- JS Dinámico -->
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">ID Venta</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th class="money-col">Total</th>
                            <th>Estado</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="sales-body">
                        <!-- Ventas dinámicas -->
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        let allSales = [];

        document.addEventListener('DOMContentLoaded', () => {
            renderSales();
            setupSearch();
        });

        async function renderSales() {
            const tbody = document.getElementById('sales-body');
            const currentUser = JSON.parse(localStorage.getItem('currentUser'));
            const isAdmin = currentUser && (currentUser.role === 'Admin' || currentUser.role === 'admin');

            tbody.innerHTML = '<tr><td colspan="6" class="text-center py-5">Cargando datos desde la nube... <div class="spinner-border spinner-border-sm text-warning ms-2"></div></td></tr>';

            // Ocultar cabecera de dinero si no es admin
            if (!isAdmin) {
                document.querySelectorAll('.money-col').forEach(el => el.classList.add('d-none'));
            }

            try {
                const res = await fetch('/api/ventas');
                const data = await res.json();
                
                if (data.success) {
                    allSales = data.ventas;
                    tbody.innerHTML = '';
                    if (allSales.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-5 text-muted">No hay ventas registradas todavía.</td></tr>';
                        return;
                    }

                    allSales.forEach((sale) => {
                        try {
                            const date = sale.fecha_compra ? new Date(sale.fecha_compra).toLocaleString() : 'F. Desconocida';
                            const estadoLogistico = sale.estado_logistico || 'En espera';
                            const estadoPedido = sale.estado_pedido || 'Pagado';
                            const isAnulada = estadoPedido.includes('Anulado');
                            
                            const badgeLogistico = isAnulada ? 
                                `<span class="badge bg-secondary opacity-50 px-3 py-2 fw-bold">ANULADO</span>` :
                                `<span class="badge ${estadoLogistico === 'Entregado' ? 'bg-success' : 'bg-warning text-dark'} shadow-sm px-3 py-2 fw-bold">${estadoLogistico.toUpperCase()}</span>`;
                            
                            const total = sale.total_venta ? parseFloat(sale.total_venta).toFixed(2) : '0.00';
                            const codigoLimpio = (sale.codigo_boleta || 'ORD-000').replace('ORD-', '');
                            
                            tbody.innerHTML += `
                                <tr class="${isAnulada ? 'table-light opacity-75' : ''}">
                                    <td class="ps-4 fw-bold">#${codigoLimpio}</td>
                                    <td>${date}</td>
                                    <td>
                                        <div class="fw-semibold">${sale.cliente_nombre || 'Cliente'}</div>
                                        <small class="text-muted">${isAnulada ? '<span class="text-danger fw-bold">Defecto Técnico</span>' : 'Venta Regular'}</small>
                                    </td>
                                    <td class="fw-bold ${isAdmin ? '' : 'd-none'}">
                                        <span class="${isAnulada ? 'text-decoration-line-through text-danger' : 'text-dark'}">S/ ${total}</span>
                                    </td>
                                    <td>${badgeLogistico}</td>
                                    <td class="text-end pe-4">
                                        <a href="/boleta/${codigoLimpio}" class="btn btn-sm btn-outline-dark me-1" title="Ver Boleta"><i class="bi bi-file-earmark-text"></i></a>
                                        ${isAdmin && !isAnulada ? `
                                        <button class="btn btn-sm btn-outline-danger" onclick="annulSale(${sale.id}, '${codigoLimpio}')" title="Anular por Defecto">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                        ` : ''}
                                        ${isAdmin ? `
                                        <button class="btn btn-sm btn-link text-muted p-0 ms-2" onclick="deleteSale(${sale.id})" title="Eliminar Permanente"><i class="bi bi-trash small"></i></button>
                                        ` : ''}
                                    </td>
                                </tr>
                            `;
                        } catch (e) { console.error("Error en fila:", e); }
                    });
                } else {
                    tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5 text-danger">Error del servidor: ${data.message || 'No se pudo obtener la lista'}.</td></tr>`;
                }
            } catch (error) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5 text-danger">Error de conexión.</td></tr>`;
            }
        }

        function setupSearch() {
            const input = document.getElementById('dispatch-search');
            const resultDiv = document.getElementById('search-result');

            input.addEventListener('input', (e) => {
                const val = e.target.value.trim().toLowerCase();
                if(val.length > 0) {
                    const match = allSales.find(s => s.codigo_boleta.toLowerCase().includes(val) || s.codigo_boleta.replace('ORD-', '').includes(val));
                    if(match) {
                        resultDiv.classList.remove('d-none');
                        const status = match.estado_logistico || 'En espera';
                        resultDiv.innerHTML = `
                            <div class="alert bg-white text-dark d-flex justify-content-between align-items-center shadow rounded-3 border-0">
                                <div>
                                    <span class="badge bg-dark mb-2">PEDIDO ENCONTRADO</span>
                                    <h6 class="fw-bold mb-1">Boleta #${match.codigo_boleta.replace('ORD-', '')} - ${match.cliente_nombre || 'Cliente'}</h6>
                                    <div class="d-flex gap-2 align-items-center">
                                        <span class="badge ${badgeClass} text-uppercase">${status}</span>
                                        <small class="text-muted">| Total: <b>S/ ${parseFloat(match.total_venta).toFixed(2)}</b></small>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="/boleta/${match.codigo_boleta.replace('ORD-', '')}" target="_blank" class="btn btn-warning fw-bold px-4">
                                        <i class="bi bi-file-earmark-text me-2"></i>VER BOLETA
                                    </a>
                                </div>
                            </div>
                        `;
                    } else {
                        resultDiv.innerHTML = '<p class="text-warning small mt-2">No se encontró ninguna boleta con ese código.</p>';
                        resultDiv.classList.remove('d-none');
                    }
                } else {
                    resultDiv.classList.add('d-none');
                }
            });
        }

        window.fastConfirm = async (code) => {
            const result = await Swal.fire({
                title: '¿Confirmar entrega?',
                text: `¿Deseas marcar la boleta #${code.replace('ORD-', '')} como ENTREGADA?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, entregada',
                cancelButtonText: 'No todavía',
                reverseButtons: true
            });

            if(!result.isConfirmed) return;

            try {
                const res = await fetch('/api/ventas/actualizar-logistica', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ codigo: code, estado: 'Entregado' })
                });
                const data = await res.json();
                if(data.success) {
                    Swal.fire({
                        title: '¡Actualizado!',
                        text: 'La boleta ha sido marcada como entregada.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    });
                    document.getElementById('dispatch-search').value = '';
                    document.getElementById('search-result').classList.add('d-none');
                    renderSales();
                }
            } catch(e) { 
                console.error(e); 
                Swal.fire('Error', 'Hubo un problema de conexión.', 'error');
            }
        };

        async function annulSale(id) {
            const { value: motivo } = await Swal.fire({
                title: '¿Estás seguro de anular esta venta?',
                text: "La venta se marcará como DEFECTUOSA y no sumará a las ganancias. Escribe el motivo de la falla:",
                input: 'text',
                inputPlaceholder: 'Ej: Motor quemado, producto roto...',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, anular por falla',
                cancelButtonText: 'Cancelar',
                inputValidator: (value) => {
                    if (!value) {
                        return '¡Debes escribir el motivo de la falla!'
                    }
                }
            });

            if (motivo) {
                try {
                    const response = await fetch('/api/ventas/anular', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id, motivo })
                    });
                    const result = await response.json();
                    if (result.success) {
                        Swal.fire('Anulada', 'La venta ha sido registrada como merma.', 'success');
                        renderSales();
                    }
                } catch (error) {
                    Swal.fire('Error', 'No se pudo anular la venta', 'error');
                }
            }
        }

        async function deleteSale(id) {
            const result = await Swal.fire({
                title: '¿Eliminar registro?',
                text: '¿Deseas eliminar este registro de venta DEFINITIVAMENTE de la base de datos?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            });

            if(result.isConfirmed) {
                try {
                    await fetch('/api/ventas/' + id, { method: 'DELETE' });
                    Swal.fire('Eliminado', 'La venta ha sido borrada.', 'success');
                    renderSales();
                } catch(err) { 
                    Swal.fire('Error', 'No se pudo eliminar el registro.', 'error');
                }
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
