<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boleta de Venta - Ferretería Palacios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Courier New', Courier, monospace; }
        .invoice-box {
            max-width: 800px;
            margin: 50px auto;
            padding: 40px;
            background: white;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            border-top: 10px solid #ffc107;
        }
        .invoice-header { border-bottom: 2px dashed #eee; padding-bottom: 20px; margin-bottom: 20px; }
        .invoice-title { color: #ffc107; font-weight: bold; }
        .table-invoice thead { background: #fdfdfd; }
        .total-row { background: #fffbeb; font-weight: bold; font-size: 1.2rem; }
        @media print {
            body { background: white; }
            .invoice-box { box-shadow: none; margin: 0; width: 100%; border: none; }
            .no-print { display: none; }
        }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
</head>
<body>

    <div class="container no-print mt-4 text-center">
        <button class="btn btn-dark fw-bold px-4 me-2" onclick="window.print()"><i class="bi bi-printer me-2"></i>Imprimir Boleta</button>
        <a href="/" class="btn btn-outline-warning fw-bold px-4">Volver a la Tienda</a>
    </div>

    <div class="invoice-box" id="invoice-content">
        <div class="invoice-header d-flex justify-content-between align-items-start">
            <div>
                <h2 class="invoice-title mb-0">FERRETERÍA PALACIOS S.A.C.</h2>
                <p class="mb-0 text-muted small">R.U.C.: 20456789123</p>
                <p class="mb-0 text-muted small">Chao 13630, Nuevo Chao, Virú, La Libertad, Perú</p>
                <p class="mb-0 text-muted small">Tel: (01) 456-7890</p>
            </div>
            <div class="text-end">
                <h4 class="fw-bold">BOLETA ELECTRÓNICA</h4>
                <p class="fs-5 fw-bold text-danger" id="invoice-id">B001-0000</p>
                <p class="mb-0 small text-muted" id="invoice-date">Fecha: --/--/----</p>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-6">
                <h6 class="fw-bold text-muted text-uppercase small mb-2">Cliente:</h6>
                <p class="mb-0 fw-bold" id="client-name">---</p>
                <p class="mb-0 small">D.N.I.: 45892314</p>
                <p class="mb-0 small text-muted">Dirección: Lima, Perú</p>
            </div>
            <div class="col-6 text-end">
                <h6 class="fw-bold text-muted text-uppercase small mb-2">Pago:</h6>
                <p class="mb-0 fw-bold">PAGO ONLINE</p>
                <p class="mb-0 small text-muted">Operación: #<%= orderId %></p>
            </div>
        </div>

        <table class="table table-invoice align-middle">
            <thead>
                <tr class="small text-muted">
                    <th>DESCRIPCIÓN</th>
                    <th class="text-center">CANT.</th>
                    <th class="text-end">P. UNIT.</th>
                    <th class="text-end">TOTAL</th>
                </tr>
            </thead>
            <tbody id="invoice-items">
                <!-- Items dinámicos -->
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="2"></td>
                    <td class="text-end text-muted small">Subtotal:</td>
                    <td class="text-end small" id="subtotal">S/ 0.00</td>
                </tr>
                <tr>
                    <td colspan="2"></td>
                    <td class="text-end text-muted small">IGV (18%):</td>
                    <td class="text-end small" id="igv">S/ 0.00</td>
                </tr>
                <tr class="total-row">
                    <td colspan="2"></td>
                    <td class="text-end">TOTAL:</td>
                    <td class="text-end text-warning" id="total">S/ 0.00</td>
                </tr>
            </tfoot>
        </table>

        <div class="text-center mt-5 pt-4 border-top">
            <p class="small text-muted mb-1">¡Gracias por su compra!</p>
            <p class="small text-muted">Representación impresa de la Boleta de Venta Electrónica.</p>
            <div class="mt-3">
                <img src="https://upload.wikimedia.org/wikipedia/commons/d/d0/QR_code_for_URL_English_Wikipedia.svg" width="80" class="opacity-25" alt="QR">
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const orderId = '<%= orderId %>';
            const sales = JSON.parse(localStorage.getItem('sales')) || [];
            const sale = sales.find(s => s.id === 'ORD-' + orderId);

            if (!sale) {
                document.getElementById('invoice-content').innerHTML = `
                    <div class="text-center py-5">
                        <i class="bi bi-exclamation-circle fs-1 text-danger"></i>
                        <h4 class="mt-3">No se encontró la información del pedido.</h4>
                    </div>
                `;
                return;
            }

            // Llenar cabecera
            document.getElementById('invoice-id').innerText = 'B001-' + orderId;
            document.getElementById('invoice-date').innerText = 'Fecha: ' + sale.date.split(',')[0];
            document.getElementById('client-name').innerText = sale.customer;

            // Llenar items
            const itemsContainer = document.getElementById('invoice-items');
            itemsContainer.innerHTML = '';
            
            let totalBase = 0;

            sale.items.forEach(item => {
                // Si por alguna razón no tiene basePrice, lo calculamos
                const basePrice = item.basePrice || (item.price / 1.18);
                const lineSubtotal = basePrice * item.quantity;
                totalBase += lineSubtotal;

                itemsContainer.innerHTML += `
                    <tr>
                        <td>
                            <div class="fw-bold text-dark">${item.name}</div>
                            <small class="text-muted">Cod: ${item.id}</small>
                        </td>
                        <td class="text-center">${item.quantity}</td>
                        <td class="text-end">S/ ${basePrice.toFixed(2)}</td>
                        <td class="text-end">S/ ${lineSubtotal.toFixed(2)}</td>
                    </tr>
                `;
            });

            // Cálculos finales basados en el Subtotal
            const subtotal = totalBase;
            const igv = subtotal * 0.18;
            const totalFinal = subtotal + igv;

            document.getElementById('subtotal').innerText = 'S/ ' + subtotal.toFixed(2);
            document.getElementById('igv').innerText = 'S/ ' + igv.toFixed(2);
            document.getElementById('total').innerText = 'S/ ' + totalFinal.toFixed(2);
        });
    </script>
</body>
</html>
