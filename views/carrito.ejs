<%- include('header') %>

<main class="container mt-5">
    <div class="row">
        <!-- Lista de Productos en el Carrito -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2 text-warning"></i>Mi Carrito</h2>
                
                <div id="cart-table-container">
                    <!-- Cargando... o Carrito vacío -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-warning" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a href="/" class="btn btn-link text-warning fw-bold text-decoration-none p-0">
                        <i class="bi bi-arrow-left me-2"></i>Seguir comprando
                    </a>
                </div>
            </div>
        </div>

        <!-- Resumen de Compra -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 p-4 bg-dark text-white">
                <h4 class="fw-bold mb-4">Resumen</h4>
                
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-secondary">Subtotal</span>
                    <span id="summary-subtotal">S/ 0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-secondary">Envío</span>
                    <span class="text-success">Gratis</span>
                </div>
                <hr class="border-secondary">
                <div class="d-flex justify-content-between mb-4">
                    <span class="fw-bold fs-5">Total</span>
                    <span class="fw-bold fs-4 text-warning" id="summary-total">S/ 0.00</span>
                </div>

                <a href="/checkout" class="btn btn-warning w-100 fw-bold py-3 mb-3 shadow">
                    PROCEDER AL PAGO
                </a>
                
                <div class="text-center">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/2560px-Visa_Inc._logo.svg.png" height="20" class="me-2 opacity-50" alt="Visa">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/1280px-Mastercard-logo.svg.png" height="20" class="opacity-50" alt="Mastercard">
                </div>
            </div>

            <div class="mt-4 p-3 bg-light rounded-4 border-start border-4 border-warning">
                <p class="small mb-0 text-muted">
                    <i class="bi bi-shield-check me-2 text-warning"></i> Compra segura y protegida.
                </p>
            </div>
        </div>
    </div>
</main>

<script>
    // Lógica específica para la página de carrito
    document.addEventListener('DOMContentLoaded', () => {
        renderFullCart();
    });

    function renderFullCart() {
        const container = document.getElementById('cart-table-container');
        const subtotalEl = document.getElementById('summary-subtotal');
        const totalEl = document.getElementById('summary-total');

        // Obtener carrito de localStorage (o del array global si persiste en la sesión)
        // Por ahora usamos el array global de main.js si está disponible, 
        // pero en una App real se cargaría de la DB o LocalStorage.
        
        if (cart.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5">
                    <i class="bi bi-cart-x display-1 text-muted"></i>
                    <h4 class="mt-3 fw-bold">Tu carrito está vacío</h4>
                    <p class="text-muted">Parece que aún no has agregado nada.</p>
                    <a href="/" class="btn btn-warning fw-bold px-4 mt-2">Ver Productos</a>
                </div>
            `;
            subtotalEl.innerText = 'S/ 0.00';
            totalEl.innerText = 'S/ 0.00';
            return;
        }

        let html = `
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr class="text-muted small text-uppercase">
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th class="text-end">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        let total = 0;
        cart.forEach((item, index) => {
            const subtotal = item.price * item.quantity;
            total += subtotal;
            html += `
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <img src="${item.img}" class="rounded-3 me-3" style="width: 60px; height: 60px; object-fit: cover;">
                            <div>
                                <h6 class="mb-0 fw-bold">${item.name}</h6>
                                <small class="text-muted">${item.category}</small>
                            </div>
                        </div>
                    </td>
                    <td class="fw-semibold">S/ ${item.price.toFixed(2)}</td>
                    <td>
                        <div class="input-group input-group-sm" style="width: 110px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(${index}, -1)">-</button>
                            <input type="text" class="form-control text-center bg-white" value="${item.quantity}" readonly>
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(${index}, 1)">+</button>
                        </div>
                    </td>
                    <td class="text-end fw-bold text-warning">S/ ${subtotal.toFixed(2)}</td>
                    <td class="text-end">
                        <button class="btn btn-link text-danger p-0" onclick="removeFromCartPage(${index})">
                            <i class="bi bi-trash fs-5"></i>
                        </button>
                    </td>
                </tr>
            `;
        });

        html += `</tbody></table></div>`;
        container.innerHTML = html;
        subtotalEl.innerText = `S/ ${total.toFixed(2)}`;
        totalEl.innerText = `S/ ${total.toFixed(2)}`;
    }

    function changeQty(index, delta) {
        const item = cart[index];
        const newQty = item.quantity + delta;

        // Validaciones
        if (newQty < 1) return;
        
        // Obtener stock real del store
        const products = JSON.parse(localStorage.getItem('products')) || [];
        const originalProduct = products.find(p => p.id == item.id);
        
        if (originalProduct && newQty > originalProduct.stock) {
            alert(`Lo sentimos, solo quedan ${originalProduct.stock} unidades de este producto.`);
            return;
        }

        item.quantity = newQty;
        localStorage.setItem('cart', JSON.stringify(cart));
        updateCartUI();
        renderFullCart();
    }

    function removeFromCartPage(index) {
        if(confirm('¿Deseas quitar este producto del carrito?')) {
            cart.splice(index, 1);
            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartUI();
            renderFullCart();
        }
    }
</script>

<%- include('footer') %>
