<%- include('header') %>

<main class="container mt-5">
    <div class="row">
        <!-- Lista de Productos en el Carrito -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2 text-warning"></i>Mi Carrito</h2>
                
                <div id="cart-table-container">
                    <!-- Cargando... o Carrito vacío -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-warning" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a href="/" class="btn btn-link text-warning fw-bold text-decoration-none p-0">
                        <i class="bi bi-arrow-left me-2"></i>Seguir comprando
                    </a>
                </div>
            </div>
        </div>

        <!-- Resumen de Compra -->
        <div class="col-lg-4">
            <div class="card bg-dark text-white p-4 border-0 rounded-4 shadow">
                <h4 class="fw-bold mb-4">Resumen</h4>
                <div class="d-flex justify-content-between mb-2 opacity-75">
                    <span>Subtotal</span>
                    <span id="cart-subtotal">S/ 0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-4 opacity-75">
                    <span>Envío</span>
                    <span class="text-success fw-bold">Gratis</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-4 mt-2">
                    <span class="h5 mb-0">Total</span>
                    <span class="h4 mb-0 text-warning fw-bold" id="cart-total">S/ 0.00</span>
                </div>
                <button onclick="proceedToCheckout()" class="btn btn-warning w-100 fw-bold py-3 rounded-3 shadow-sm">
                    PROCEDER AL PAGO
                </button>
                <div class="text-center mt-3 opacity-50">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" height="20" class="me-2" alt="Visa">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" height="20" alt="Mastercard">
                </div>
            </div>

            <div class="mt-4 p-3 bg-light rounded-4 border-start border-4 border-warning">
                <p class="small mb-0 text-muted">
                    <i class="bi bi-shield-check me-2 text-warning"></i> Compra segura y protegida.
                </p>
            </div>
        </div>
    </div>
</main>

<script>
    // Lógica específica para la página de carrito
    document.addEventListener('DOMContentLoaded', () => {
        renderFullCart();
    });

    function updateSummary(cart) {
        const total = cart.reduce((acc, item) => acc + (item.price * item.quantity), 0);
        document.getElementById('cart-subtotal').innerText = `S/ ${total.toFixed(2)}`;
        document.getElementById('cart-total').innerText = `S/ ${total.toFixed(2)}`;
    }

    function proceedToCheckout() {
        const user = JSON.parse(localStorage.getItem('currentUser'));
        if (!user) {
            alert('Debes iniciar sesión o registrarte para proceder al pago.');
            window.location.href = '/login';
        } else {
            window.location.href = '/checkout';
        }
    }

    function renderFullCart() {
        const container = document.getElementById('cart-table-container');
        const subtotalEl = document.getElementById('cart-subtotal');
        const totalEl = document.getElementById('cart-total');

        // Obtener carrito de localStorage
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        
        if (cart.length === 0) {
            container.innerHTML = `
                <div class="text-center py-5">
                    <i class="bi bi-cart-x display-1 text-muted"></i>
                    <h4 class="mt-3 fw-bold">Tu carrito está vacío</h4>
                    <p class="text-muted">Parece que aún no has agregado nada.</p>
                    <a href="/" class="btn btn-warning fw-bold px-4 mt-2">Ver Productos</a>
                </div>
            `;
            if(subtotalEl) subtotalEl.innerText = 'S/ 0.00';
            if(totalEl) totalEl.innerText = 'S/ 0.00';
            return;
        }

        let html = `
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr class="text-muted small text-uppercase">
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th class="text-end">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        let total = 0;
        cart.forEach((item, index) => {
            const subtotal = item.price * item.quantity;
            total += subtotal;
            const itemImg = item.image || item.img || '/img/logo_ferreteria.png';
            html += `
                <tr>
                    <td>
                        <div class="d-flex align-items-center">
                            <img src="${itemImg}" class="rounded-3 me-3" style="width: 60px; height: 60px; object-fit: cover;">
                            <div>
                                <h6 class="mb-0 fw-bold">${item.name}</h6>
                                <small class="text-muted">${item.category || 'Ferretería'}</small>
                            </div>
                        </div>
                    </td>
                    <td class="fw-semibold">S/ ${item.price.toFixed(2)}</td>
                    <td>
                        <div class="input-group input-group-sm" style="width: 110px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(${index}, -1)">-</button>
                            <input type="text" class="form-control text-center bg-white" value="${item.quantity}" readonly>
                            <button class="btn btn-outline-secondary" type="button" onclick="changeQty(${index}, 1)">+</button>
                        </div>
                    </td>
                    <td class="text-end fw-bold text-warning">S/ ${subtotal.toFixed(2)}</td>
                    <td class="text-end">
                        <button class="btn btn-link text-danger p-0" onclick="removeFromCartPage(${index})">
                            <i class="bi bi-trash fs-5"></i>
                        </button>
                    </td>
                </tr>
            `;
        });

        html += `</tbody></table></div>`;
        container.innerHTML = html;
        if(subtotalEl) subtotalEl.innerText = `S/ ${total.toFixed(2)}`;
        if(totalEl) totalEl.innerText = `S/ ${total.toFixed(2)}`;
    }

    async function changeQty(index, delta) {
        const item = cart[index];
        const newQty = item.quantity + delta;

        // Validaciones
        if (newQty < 1) return;
        
        let stockDisponible = 999; // Default if API fails
        try {
            const res = await fetch('/api/productos');
            const data = await res.json();
            if (data.success) {
                const originalProduct = data.products.find(p => p.id == item.id);
                if (originalProduct) {
                    stockDisponible = originalProduct.stock;
                }
            }
        } catch(e) {}
        
        if (newQty > stockDisponible) {
            alert(`Lo sentimos, solo quedan ${stockDisponible} unidades de este producto.`);
            return;
        }

        item.quantity = newQty;
        localStorage.setItem('cart', JSON.stringify(cart));
        updateCartUI();
        renderFullCart();
    }

    function removeFromCartPage(index) {
        if(confirm('¿Deseas quitar este producto del carrito?')) {
            cart.splice(index, 1);
            localStorage.setItem('cart', JSON.stringify(cart));
            updateCartUI();
            renderFullCart();
        }
    }
</script>

<%- include('footer') %>
