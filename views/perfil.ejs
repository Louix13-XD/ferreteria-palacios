<%- include('header') %>

<main class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-warning py-4 text-center">
                    <div class="position-relative d-inline-block">
                        <img src="https://ui-avatars.com/api/?name=Juan+Perez&background=212529&color=fff&size=128" class="rounded-circle border border-4 border-white shadow" alt="Avatar">
                    </div>
                    <h3 class="fw-bold mt-3 mb-0">Juan Pérez</h3>
                    <p class="text-dark opacity-75">Cliente Oro</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Nombre Completo</label>
                            <p class="fs-5 fw-semibold border-bottom pb-2">Juan Pérez García</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Correo Electrónico</label>
                            <p class="fs-5 fw-semibold border-bottom pb-2">juan.perez@email.com</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Teléfono</label>
                            <p class="fs-5 fw-semibold border-bottom pb-2">+51 987 654 321</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Fecha de Registro</label>
                            <p class="fs-5 fw-semibold border-bottom pb-2">15 de Marzo, 2024</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold text-uppercase">Dirección Principal</label>
                            <p class="fs-5 fw-semibold border-bottom pb-2" id="profile-address">Cargando...</p>
                        </div>
                    </div>
                    <div class="mt-5 d-flex gap-2">
                        <button class="btn btn-warning fw-bold px-4" data-bs-toggle="modal" data-bs-target="#modalEditarPerfil">
                            <i class="bi bi-pencil-square me-2"></i>Editar Perfil
                        </button>
                        <button class="btn btn-outline-dark fw-bold px-4" onclick="logout()">
                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                        </button>
                        <a href="/admin" id="profile-admin-btn" class="btn btn-dark fw-bold px-4 d-none">
                            <i class="bi bi-speedometer2 me-2"></i>Ir al Panel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Editar Perfil -->
    <div class="modal fade" id="modalEditarPerfil" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title fw-bold">Editar Mis Datos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="formEditProfile">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Nombre Completo</label>
                            <input type="text" class="form-control" id="edit-nombre" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Correo Electrónico</label>
                            <input type="email" class="form-control" id="edit-correo" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Teléfono</label>
                            <input type="text" class="form-control" id="edit-telefono">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Dirección</label>
                            <textarea class="form-control" id="edit-direccion" rows="2"></textarea>
                        </div>
                        <button type="submit" class="btn btn-dark w-100 fw-bold">Guardar Cambios</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const currentUser = JSON.parse(localStorage.getItem('currentUser'));
        
        if (!currentUser) {
            window.location.href = '/login';
            return;
        }

        // Llenar datos dinámicos
        document.querySelector('.card-header img').src = `https://ui-avatars.com/api/?name=${encodeURIComponent(currentUser.name)}&background=212529&color=fff&size=128`;
        document.querySelector('.card-header h3').innerText = currentUser.name;
        document.querySelector('.card-header p').style.display = 'none';
        
        // Mostrar botón de panel administrativo si no es cliente
        const adminBtn = document.getElementById('profile-admin-btn');
        if (currentUser.role !== 'client' && currentUser.role !== 'Cliente' && adminBtn) {
            adminBtn.classList.remove('d-none');
        }
        
        const labels = document.querySelectorAll('.fs-5.fw-semibold');
        labels[0].innerText = currentUser.name;
        labels[1].innerText = currentUser.email || 'usuario@email.com';
        labels[2].innerText = currentUser.phone || '---';
        document.getElementById('profile-address').innerText = currentUser.address || 'Sin dirección registrada';
        
        // Pre-llenar modal
        document.getElementById('edit-nombre').value = currentUser.name;
        document.getElementById('edit-correo').value = currentUser.email || '';
        document.getElementById('edit-telefono').value = currentUser.phone || '';
        document.getElementById('edit-direccion').value = currentUser.address || '';
    });

    function logout() {
        if(confirm('¿Estás seguro de que deseas cerrar sesión?')) {
            localStorage.removeItem('currentUser');
            window.location.href = '/';
        }
    }

    document.getElementById('formEditProfile')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        const nuevoNombre = document.getElementById('edit-nombre').value;
        const nuevoCorreo = document.getElementById('edit-correo').value;
        const nuevoTelefono = document.getElementById('edit-telefono').value;
        const nuevaDireccion = document.getElementById('edit-direccion').value;
        
        const currentUser = JSON.parse(localStorage.getItem('currentUser'));
        
        const payload = {
            nombre_completo: nuevoNombre,
            email: nuevoCorreo,
            celular: nuevoTelefono,
            direccion_zona: nuevaDireccion,
            rol: 'Cliente' // Mantenemos el rol
        };

        try {
            const res = await fetch(`/api/usuarios/${currentUser.id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            
            if (data.success) {
                // Actualizamos el localStorage para que la UI se mantenga al día
                currentUser.name = nuevoNombre;
                currentUser.email = nuevoCorreo;
                currentUser.phone = nuevoTelefono;
                currentUser.address = nuevaDireccion;
                localStorage.setItem('currentUser', JSON.stringify(currentUser));
                
                alert('¡Perfil actualizado con éxito!');
                location.reload();
            } else {
                alert('Error al actualizar: ' + data.message);
            }
        } catch (error) {
            console.error(error);
            alert('Error de conexión al servidor.');
        }
    });
</script>

<%- include('footer') %>
