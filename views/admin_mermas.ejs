<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
        .admin-sidebar { width: 250px; height: 100vh; position: fixed; background: #212529; color: white; }
        .admin-content { margin-left: 250px; padding: 30px; }
        .card-merma { border-left: 5px solid #dc3545; transition: transform 0.2s; }
        .card-merma:hover { transform: translateY(-5px); }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
</head>
<body>

    <%- include('admin_sidebar') %>

    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">Gestión de Mermas</h2>
                <p class="text-muted">Productos defectuosos y devoluciones técnicas.</p>
            </div>
            <div class="bg-danger text-white px-4 py-2 rounded-pill fw-bold shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>REPORTE DE PÉRDIDAS
            </div>
        </div>

        <div class="row" id="mermas-container">
            <!-- Dinámico -->
            <div class="col-12 text-center py-5">
                <div class="spinner-border text-danger"></div>
                <p class="mt-2">Cargando registros de fallas...</p>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', renderMermas);

        async function renderMermas() {
            const container = document.getElementById('mermas-container');
            try {
                const res = await fetch('/api/ventas');
                const data = await res.json();

                if (data.success) {
                    const mermas = data.ventas.filter(v => v.estado_pedido && v.estado_pedido.includes('Anulado'));
                    container.innerHTML = '';

                    if (mermas.length === 0) {
                        container.innerHTML = `
                            <div class="col-12 text-center py-5">
                                <i class="bi bi-check-circle text-success display-1"></i>
                                <h4 class="mt-3 fw-bold">Sin mermas registradas</h4>
                                <p class="text-muted">No se han reportado productos defectuosos recientemente.</p>
                            </div>`;
                        return;
                    }

                    mermas.forEach(sale => {
                        const date = new Date(sale.fecha_compra).toLocaleDateString('es-PE', { day: '2-digit', month: 'long', year: 'numeric' });
                        const total = parseFloat(sale.total_venta).toFixed(2);
                        
                        container.innerHTML += `
                            <div class="col-md-6 mb-4">
                                <div class="card border-0 shadow-sm rounded-4 card-merma h-100 p-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="badge bg-light text-dark border fw-bold">#${sale.codigo_boleta}</span>
                                        <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>${date}</span>
                                    </div>
                                    <h6 class="fw-bold text-danger mb-1">MOTIVO DE LA FALLA:</h6>
                                    <p class="mb-3 p-2 bg-light rounded italic">"${sale.motivo_anulacion || 'Sin motivo especificado'}"</p>
                                    
                                    <div class="border-top pt-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <small class="text-muted d-block">Cliente:</small>
                                                <span class="fw-semibold">${sale.cliente_nombre}</span>
                                            </div>
                                            <div class="text-end">
                                                <small class="text-muted d-block">Pérdida (Monto):</small>
                                                <span class="fw-bold text-danger">S/ ${total}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                }
            } catch (error) {
                container.innerHTML = '<p class="text-danger">Error al cargar datos.</p>';
            }
        }
    </script>
</body>
</html>
