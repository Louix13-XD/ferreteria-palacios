<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #f0f2f5; font-family: 'Inter', sans-serif; }
        .admin-sidebar { width: 250px; height: 100vh; position: fixed; background: #212529; color: white; }
        .admin-content { margin-left: 250px; padding: 30px; }
        .nav-link-admin { color: rgba(255,255,255,0.7); padding: 15px 25px; display: block; text-decoration: none; border-left: 4px solid transparent; }
        .nav-link-admin:hover, .nav-link-admin.active { color: #ffc107; background: rgba(255,193,7,0.1); border-left-color: #ffc107; }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
</head>
<body>

    <%- include('admin_sidebar') %>

    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Reportes y Analítica</h2>
            <div class="d-flex gap-2">
                <select class="form-select border-0 shadow-sm" id="report-year-select">
                    <option>Año 2026</option>
                </select>
                <button class="btn btn-warning fw-bold shadow-sm px-4">Generar PDF</button>
            </div>
        </div>

        <!-- Tarjetas de Resumen -->
        <div class="row g-4 mb-4">
            <!-- Card 1 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                    <h6 class="text-muted fw-bold text-uppercase small mb-3">Ingresos Brutos (Con IGV)</h6>
                    <h3 class="fw-bold text-dark mb-0" id="report-total-sales">S/ 0.00</h3>
                    <p class="text-muted small mt-2">Monto total facturado</p>
                </div>
            </div>
            <!-- Card 2 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                    <h6 class="text-muted fw-bold text-uppercase small mb-3">Ingresos Netos (Sin IGV)</h6>
                    <h3 class="fw-bold text-success mb-0" id="report-net-income">S/ 0.00</h3>
                    <p class="text-muted small mt-2">Ganancia real libre de impuestos</p>
                </div>
            </div>
            <!-- Card 3 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                    <h6 class="text-muted fw-bold text-uppercase small mb-3">IGV Acumulado (18%)</h6>
                    <h3 class="fw-bold text-warning mb-0" id="report-total-igv">S/ 0.00</h3>
                    <p class="text-muted small mt-2">Impuesto a pagar</p>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-4">Crecimiento Mensual de Ingresos</h5>
                    <div style="height: 400px;">
                        <canvas id="growthChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <h5 class="fw-bold mb-4">Ventas por Categoría</h5>
                    <div style="height: 350px;">
                        <canvas id="salesByCatChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const currentYear = new Date().getFullYear();
            const yearSelect = document.getElementById('report-year-select');
            if(yearSelect) yearSelect.innerHTML = `<option>Año ${currentYear}</option>`;

            let sales = [];
            try {
                const res = await fetch('/api/ventas');
                const data = await res.json();
                if(data.success) sales = data.ventas;
            } catch(e) { console.error("Error al obtener ventas", e); }
            
            // Cálculos
            const gross = sales.reduce((acc, s) => acc + parseFloat(s.total_venta || 0), 0);
            const net = gross / 1.18;
            const totalIgv = gross - net;

            document.getElementById('report-total-sales').innerText = `S/ ${gross.toFixed(2)}`;
            document.getElementById('report-net-income').innerText = `S/ ${net.toFixed(2)}`;
            document.getElementById('report-total-igv').innerText = `S/ ${totalIgv.toFixed(2)}`;

            // Gráfico de Crecimiento
            const ctxGrowth = document.getElementById('growthChart').getContext('2d');
            
            // Simular datos por mes basados en las ventas reales del mes actual
            const currentMonth = new Date().getMonth();
            const monthlyData = new Array(12).fill(0);
            monthlyData[currentMonth] = gross; // Fixed error 'total' variable not found

            new Chart(ctxGrowth, {
                type: 'bar',
                data: {
                    labels: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'],
                    datasets: [{
                        label: 'Ingresos Mensuales',
                        data: monthlyData,
                        backgroundColor: '#ffc107',
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { 
                        y: { beginAtZero: true, grid: { drawBorder: false, color: '#eee' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Gráfico de Ventas por Categoría (Reales)
            try {
                const resStats = await fetch('/api/stats/sales-by-category');
                const dataStats = await resStats.json();
                
                if(dataStats.success) {
                    const stats = dataStats.stats;
                    const labels = stats.map(s => s.categoria);
                    const values = stats.map(s => parseFloat(s.total));

                    const ctxSBC = document.getElementById('salesByCatChart').getContext('2d');
                    new Chart(ctxSBC, {
                        type: 'doughnut',
                        data: {
                            labels: labels.length > 0 ? labels : ['Sin Ventas'],
                            datasets: [{
                                data: values.length > 0 ? values : [1],
                                backgroundColor: ['#ffc107', '#212529', '#0d6efd', '#198754', '#dc3545', '#6c757d'],
                                borderWidth: 0
                            }]
                        },
                        options: { 
                            responsive: true, 
                            maintainAspectRatio: false, 
                            cutout: '70%',
                            plugins: { 
                                legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 10 } } },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return `S/ ${context.raw.toFixed(2)}`;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            } catch(e) { console.error("Error al obtener stats de ventas", e); }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
