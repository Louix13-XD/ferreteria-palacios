<h5 class="fw-bold mb-3 border-bottom pb-2">Filtros</h5>

<div class="mb-4">
    <h6 class="fw-semibold">Precio</h6>
    <div id="price-filters">
        <div class="form-check mb-2">
            <input class="form-check-input filter-price" type="checkbox" id="p1" value="0-50">
            <label class="form-check-label" for="p1">S/ 0 - S/ 50</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input filter-price" type="checkbox" id="p2" value="50-200">
            <label class="form-check-label" for="p2">S/ 50 - S/ 200</label>
        </div>
        <div class="form-check mb-2">
            <input class="form-check-input filter-price" type="checkbox" id="p3" value="200+">
            <label class="form-check-label" for="p3">Más de S/ 200</label>
        </div>
    </div>
</div>

<div class="mb-4">
    <h6 class="fw-semibold">Marca</h6>
    <div id="brands-filter-container">
        <p class="text-muted small">Cargando marcas...</p>
    </div>
</div>
