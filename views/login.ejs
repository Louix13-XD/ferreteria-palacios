<%- include('header') %>

<main class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Pestañas de Navegación -->
                <ul class="nav nav-pills nav-justified bg-light p-2" id="loginTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold py-3" id="login-tab" data-bs-toggle="pill" data-bs-target="#login" type="button" role="tab">INICIAR SESIÓN</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold py-3" id="register-tab" data-bs-toggle="pill" data-bs-target="#register" type="button" role="tab">REGISTRARSE</button>
                    </li>
                </ul>

                <div class="card-body p-4 p-md-5 tab-content">
                    <!-- Formulario de Inicio de Sesión -->
                    <div class="tab-pane fade show active" id="login" role="tabpanel">
                        <div class="text-center mb-4">
                            <i class="bi bi-person-circle display-1 text-warning"></i>
                            <h4 class="fw-bold mt-2">¡Hola de nuevo!</h4>
                            <p class="text-muted">Ingresa tus credenciales para continuar</p>
                        </div>
                        <form id="formLogin">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Correo Electrónico</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-envelope"></i></span>
                                    <input type="text" class="form-control border-start-0" id="login-user" required>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-lock"></i></span>
                                    <input type="password" class="form-control border-start-0" id="login-pass" required>
                                </div>
                                <div class="text-end mt-2">
                                    <a href="#" class="text-warning text-decoration-none small fw-bold">¿Olvidaste tu contraseña?</a>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-warning w-100 fw-bold py-3 shadow-sm">INGRESAR</button>
                        </form>
                    </div>

                    <!-- Formulario de Registro -->
                    <div class="tab-pane fade" id="register" role="tabpanel">
                        <div class="text-center mb-4">
                            <h4 class="fw-bold">Crea tu cuenta</h4>
                            <p class="text-muted">Únete a la familia Ferretería Palacios</p>
                        </div>
                        <form id="formRegister">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Nombre Completo</label>
                                <input type="text" class="form-control" id="reg-name" placeholder="Ej. Juan Pérez" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Correo Electrónico</label>
                                <input type="email" class="form-control" id="reg-email" placeholder="correo@ejemplo.com" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Número Celular</label>
                                <input type="tel" class="form-control" id="reg-phone" placeholder="987 654 321" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Dirección</label>
                                <input type="text" class="form-control" id="reg-address" placeholder="Ej. Av. Principal 123, Nuevo Chao" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Contraseña</label>
                                <input type="password" class="form-control" id="reg-pass" placeholder="Mínimo 8 caracteres" required>
                            </div>
                            <button type="submit" class="btn btn-dark w-100 fw-bold py-2 mt-2">CREAR CUENTA</button>
                        </form>
                    </div>
                </div>
                
                <div class="card-footer bg-white border-0 text-center pb-4">
                    <p class="text-muted small">Al continuar, aceptas nuestras políticas de privacidad.</p>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Manejo de Registro con Backend
        const formRegister = document.getElementById('formRegister');
        formRegister.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = formRegister.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerText = 'Cargando...';

            const payload = {
                name: document.getElementById('reg-name').value,
                email: document.getElementById('reg-email').value,
                phone: document.getElementById('reg-phone').value,
                address: document.getElementById('reg-address').value,
                password: document.getElementById('reg-pass').value
            };
            
            try {
                const res = await fetch('/api/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                
                if(data.success) {
                    alert("¡Cuenta creada con éxito! Ahora puedes iniciar sesión.");
                    location.reload();
                } else {
                    alert(data.message);
                    btn.disabled = false;
                    btn.innerText = 'CREAR CUENTA';
                }
            } catch(error) {
                alert("Error de conexión al registrar.");
                btn.disabled = false;
                btn.innerText = 'CREAR CUENTA';
            }
        });

        // Manejo de Login con Backend
        const formLogin = document.getElementById('formLogin');
        formLogin.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = formLogin.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerText = 'Ingresando...';

            const payload = {
                username: document.getElementById('login-user').value,
                password: document.getElementById('login-pass').value
            };

            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();

                if (data.success) {
                    // Mantenemos compatibilidad de vistas
                    localStorage.setItem('currentUser', JSON.stringify(data.user));
                    
                    const rol = data.user.role;
                    if (rol === 'Admin' || rol === 'Supervisor' || rol === 'Trabajador_Ventas' || rol === 'Trabajador_Almacen') {
                        window.location.href = '/admin';
                    } else {
                        window.location.href = '/perfil';
                    }
                } else {
                    alert(data.message || "Credenciales incorrectas.");
                    btn.disabled = false;
                    btn.innerText = 'INGRESAR';
                }
            } catch (error) {
                alert("Error de conexión al iniciar sesión.");
                btn.disabled = false;
                btn.innerText = 'INGRESAR';
            }
        });
    });
</script>

<%- include('footer') %>
