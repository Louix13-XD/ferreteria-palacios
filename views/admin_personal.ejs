<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body { background-color: #f0f2f5; font-family: 'Inter', sans-serif; }
        .admin-sidebar { width: 250px; height: 100vh; position: fixed; background: #212529; color: white; }
        .admin-content { margin-left: 250px; padding: 30px; }
        .nav-link-admin { color: rgba(255,255,255,0.7); padding: 15px 25px; display: block; text-decoration: none; border-left: 4px solid transparent; }
        .nav-link-admin:hover, .nav-link-admin.active { color: #ffc107; background: rgba(255,193,7,0.1); border-left-color: #ffc107; }
        .user-avatar { width: 40px; height: 40px; object-fit: cover; border-radius: 50%; }
    </style>
    <link rel="icon" type="image/png" href="/img/logo_ferreteria.png">
</head>
<body>

    <%- include('admin_sidebar') %>

    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Gestión de Personal</h2>
                <p class="text-muted">Cuentas creadas para trabajadores y colaboradores internos.</p>
            </div>
            <button class="btn btn-dark fw-bold shadow-sm d-none" id="btn-add-worker" data-bs-toggle="modal" data-bs-target="#modalNuevoUsuario">
                <i class="bi bi-person-badge-fill me-2"></i>Registrar Trabajador
            </button>
        </div>

        <div class="row g-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="p-4 bg-white border-bottom">
                        <h5 class="fw-bold mb-0">Equipo de Trabajo</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="small text-uppercase text-muted">
                                    <th class="ps-4">Personal</th>
                                    <th>Cargo</th>
                                    <th>Email</th>
                                    <th>DNI</th>
                                    <th>Celular</th>
                                    <th>Estado</th>
                                    <th class="text-end pe-4">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="workers-table-body">
                                <!-- Carga dinámica -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal Nuevo Usuario -->
    <div class="modal fade" id="modalNuevoUsuario" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold">Nuevo Perfil de Personal</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="formNuevoTrabajador">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small">Nombre Completo</label>
                                <input type="text" class="form-control" id="work-name" placeholder="Ej. Roberto Gomez" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small text-primary">Nombre de Usuario (Login)</label>
                                <input type="text" class="form-control border-primary" id="work-user" placeholder="ej. rgomez2024" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold small">DNI</label>
                                <input type="text" class="form-control" id="work-dni" placeholder="8 dígitos" required maxlength="8">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold small">Correo Electrónico</label>
                                <input type="email" class="form-control" id="work-email" placeholder="usuario@email.com" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold small">Número Celular</label>
                                <input type="tel" class="form-control" id="work-phone" placeholder="987 654 321" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Cargo / Rol</label>
                            <select class="form-select" id="work-role">
                                <option value="Admin">Administrador</option>
                                <option value="Trabajador">Trabajador</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Zona / Dirección de Residencia</label>
                            <input type="text" class="form-control" id="work-zone" placeholder="Ej. Av. Las Flores 123, Lima" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small">Contraseña</label>
                            <input type="password" class="form-control" id="work-pass" required>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold py-2 shadow">CREAR USUARIO</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Editar Usuario -->
    <div class="modal fade" id="modalEditarUsuario" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold">Editar Perfil de Personal</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="formEditarTrabajador">
                        <input type="hidden" id="edit-work-index">
                        <input type="hidden" id="edit-work-id">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small">Nombre Completo</label>
                                <input type="text" class="form-control" id="edit-work-name" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold small text-primary">Nombre de Usuario (Login)</label>
                                <input type="text" class="form-control border-primary" id="edit-work-user" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold small">DNI</label>
                                <input type="text" class="form-control" id="edit-work-dni" required maxlength="8">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold small">Correo Electrónico</label>
                                <input type="email" class="form-control" id="edit-work-email" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold small">Número Celular</label>
                                <input type="tel" class="form-control" id="edit-work-phone" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Cargo / Rol</label>
                            <select class="form-select" id="edit-work-role">
                                <option value="Admin">Administrador</option>
                                <option value="Trabajador">Trabajador</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Zona / Dirección</label>
                            <input type="text" class="form-control" id="edit-work-zone" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small">Contraseña (Dejar en blanco para no cambiar)</label>
                            <input type="password" class="form-control" id="edit-work-pass">
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold py-2 shadow">GUARDAR CAMBIOS</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        let allWorkers = [];

        document.addEventListener('DOMContentLoaded', () => {
            const currentUser = JSON.parse(localStorage.getItem('currentUser'));
            if (!currentUser) { window.location.href = '/login'; return; }
            if (currentUser.role && currentUser.role.includes('Trabajador')) {
                alert('No tienes permisos.'); window.location.href = '/admin'; return;
            }

            const createBtn = document.getElementById('btn-add-worker');
            if (createBtn && (currentUser.role === 'admin' || currentUser.role === 'Admin')) {
                createBtn.classList.remove('d-none');
            }

            fetchWorkers();
        });

        async function fetchWorkers() {
            try {
                const res = await fetch('/api/usuarios');
                const data = await res.json();
                if (data.success) {
                    allWorkers = data.usuarios;
                    renderWorkers();
                }
            } catch (e) {
                console.error('Error al cargar usuarios:', e);
            }
        }

        function renderWorkers() {
            const currentUser = JSON.parse(localStorage.getItem('currentUser'));
            const tbody = document.getElementById('workers-table-body');
            tbody.innerHTML = '';

            let filtered = allWorkers;
            if (currentUser.role !== 'Admin' && currentUser.role !== 'admin') {
                filtered = allWorkers.filter(w => w.rol === 'Trabajador_Ventas' || w.rol === 'Trabajador_Almacen');
            }

            filtered.forEach((worker, index) => {
                const roleDisplay = worker.rol === 'Admin' ? 'Administrador' : 'Trabajador';
                tbody.innerHTML += `
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=${encodeURIComponent(worker.nombre_completo)}&background=random" class="user-avatar me-3 shadow-sm">
                                <div>
                                    <p class="fw-bold mb-0">${worker.nombre_completo}</p>
                                    <small class="text-muted">ID: ${worker.codigo_interno || worker.id}</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary px-3 fw-bold">${roleDisplay}</span></td>
                        <td class="text-muted">${worker.email}</td>
                        <td class="text-muted">${worker.dni || '---'}</td>
                        <td class="text-muted">${worker.celular || '---'}</td>
                        <td><span class="badge bg-success rounded-pill px-3">${worker.estado || 'Activo'}</span></td>
                        <td class="text-end pe-4">
                            ${currentUser.role === 'admin' || currentUser.role === 'Admin' ? `
                                <button class="btn btn-sm btn-outline-dark me-1" onclick="openEditWorker(${worker.id})"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteWorker(${worker.id})"><i class="bi bi-trash"></i></button>
                            ` : '<span class="text-muted small">Solo lectura</span>'}
                        </td>
                    </tr>
                `;
            });
        }

        document.getElementById('formNuevoTrabajador').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = this.querySelector('button[type="submit"]');
            btn.disabled = true;

            const roleVal = document.getElementById('work-role').value; // 'Admin' o 'Trabajador'
            const dbRol = roleVal === 'Trabajador' ? 'Trabajador_Ventas' : 'Admin';
            const prefix = roleVal === 'Admin' ? 'FP-ADMIN-' : 'FP-TRBJ-';
            const count = allWorkers.filter(w => w.rol === dbRol).length + 1;
            const code = prefix + count.toString().padStart(4, '0');

            const payload = {
                codigo_interno: code,
                nombre_completo: document.getElementById('work-name').value,
                username: document.getElementById('work-user').value,
                dni: document.getElementById('work-dni').value,
                email: document.getElementById('work-email').value,
                celular: document.getElementById('work-phone').value,
                direccion_zona: document.getElementById('work-zone').value,
                password: document.getElementById('work-pass').value,
                rol: dbRol
            };

            try {
                const res = await fetch('/api/usuarios', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('modalNuevoUsuario')).hide();
                    this.reset();
                    fetchWorkers();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch(e) { alert('Error de conexión'); }
            btn.disabled = false;
        });

        function openEditWorker(id) {
            const w = allWorkers.find(x => x.id === id);
            if(!w) return;

            document.getElementById('edit-work-id').value = w.id;
            document.getElementById('edit-work-name').value = w.nombre_completo;
            document.getElementById('edit-work-user').value = w.username || '';
            document.getElementById('edit-work-dni').value = w.dni || '';
            document.getElementById('edit-work-email').value = w.email || '';
            document.getElementById('edit-work-phone').value = w.celular || '';
            document.getElementById('edit-work-role').value = w.rol === 'Admin' ? 'Admin' : 'Trabajador';
            document.getElementById('edit-work-zone').value = w.direccion_zona || '';
            document.getElementById('edit-work-pass').value = '';

            const modal = new bootstrap.Modal(document.getElementById('modalEditarUsuario'));
            modal.show();
        }

        document.getElementById('formEditarTrabajador').addEventListener('submit', async function(e) {
            e.preventDefault();
            const id = document.getElementById('edit-work-id').value;
            const roleVal = document.getElementById('edit-work-role').value;
            const dbRol = roleVal === 'Trabajador' ? 'Trabajador_Ventas' : 'Admin';

            const payload = {
                nombre_completo: document.getElementById('edit-work-name').value,
                username: document.getElementById('edit-work-user').value,
                dni: document.getElementById('edit-work-dni').value,
                email: document.getElementById('edit-work-email').value,
                celular: document.getElementById('edit-work-phone').value,
                direccion_zona: document.getElementById('edit-work-zone').value,
                rol: dbRol,
                password: document.getElementById('edit-work-pass').value
            };

            try {
                const res = await fetch('/api/usuarios/' + id, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if ((await res.json()).success) {
                    bootstrap.Modal.getInstance(document.getElementById('modalEditarUsuario')).hide();
                    fetchWorkers();
                }
            } catch(e) { alert('Error de red'); }
        });

        async function deleteWorker(id) {
            const result = await Swal.fire({
                title: '¿Eliminar personal?',
                text: '¿Estás seguro de que deseas eliminar a este usuario del equipo?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            });

            if (result.isConfirmed) {
                try {
                    const res = await fetch('/api/usuarios/' + id, { method: 'DELETE' });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({
                            title: '¡Eliminado!',
                            text: 'El colaborador ha sido retirado.',
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false
                        });
                        fetchWorkers();
                    }
                } catch(e) { 
                    Swal.fire('Error', 'No se pudo eliminar al usuario.', 'error');
                }
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
