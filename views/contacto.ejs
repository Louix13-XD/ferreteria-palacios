<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contáctanos - Ferretería Palacios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #f8f9fa; }
        .contact-hero {
            background: linear-gradient(135deg, #212529 0%, #343a40 100%);
            color: white;
            padding: 100px 0;
            border-radius: 0 0 50px 50px;
            margin-bottom: -50px;
        }
        .contact-card {
            background: white;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            overflow: hidden;
            border: none;
        }
        .info-box {
            background: #ffc107;
            color: #212529;
            padding: 40px;
            height: 100%;
        }
        .form-control {
            border-radius: 12px;
            padding: 12px 20px;
            border: 1px solid #eee;
            background: #fdfdfd;
        }
        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(255,193,7,0.1);
            border-color: #ffc107;
        }
        .btn-send {
            background: #212529;
            color: white;
            border-radius: 15px;
            padding: 15px 30px;
            font-weight: 700;
            letter-spacing: 1px;
            transition: all 0.3s;
            border: none;
        }
        .btn-send:hover {
            background: #ffc107;
            color: #212529;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255,193,7,0.3);
        }
        .social-icon {
            width: 45px;
            height: 45px;
            background: rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            color: white;
            text-decoration: none;
            transition: all 0.3s;
        }
        .social-icon:hover {
            background: #ffc107;
            color: #212529;
            transform: rotate(10deg);
        }
    </style>
</head>
<body>

    <%- include('header') %>

    <section class="contact-hero text-center">
        <div class="container">
            <h1 class="display-4 fw-bold mb-3">¿Cómo podemos ayudarte?</h1>
            <p class="lead opacity-75">Estamos aquí para resolver tus dudas y apoyarte en tus proyectos.</p>
        </div>
    </section>

    <div class="container pb-5">
        <div class="contact-card card mx-auto" style="max-width: 1000px;">
            <div class="row g-0">
                <div class="col-lg-5">
                    <div class="info-box d-flex flex-column justify-content-between">
                        <div>
                            <h3 class="fw-bold mb-4">Información de Contacto</h3>
                            <p class="mb-5 opacity-75">Envíanos un mensaje y nuestro equipo te responderá en menos de 24 horas.</p>
                            
                            <div class="d-flex align-items-center mb-4">
                                <i class="bi bi-geo-alt-fill fs-4 me-3"></i>
                                <span>Chao 13630, Nuevo Chao, Virú, La Libertad</span>
                            </div>
                            <div class="d-flex align-items-center mb-4">
                                <i class="bi bi-telephone-fill fs-4 me-3"></i>
                                <span>+51 987 654 321</span>
                            </div>
                            <div class="d-flex align-items-center mb-4">
                                <i class="bi bi-envelope-fill fs-4 me-3"></i>
                                <span>ventas@ferreteriapalacios.com</span>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <a href="#" class="social-icon" style="background: rgba(0,0,0,0.1)"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="social-icon" style="background: rgba(0,0,0,0.1)"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="social-icon" style="background: rgba(0,0,0,0.1)"><i class="bi bi-whatsapp"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-7 p-4 p-md-5">
                    <form id="contactForm">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Nombre Completo</label>
                                <input type="text" class="form-control" placeholder="Tu nombre" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Correo Electrónico</label>
                                <input type="email" class="form-control" placeholder="nombre@ejemplo.com" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small">Asunto</label>
                                <select class="form-select form-control">
                                    <option>Cotización de productos</option>
                                    <option>Estado de mi pedido</option>
                                    <option>Soporte técnico</option>
                                    <option>Otro</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small">Mensaje</label>
                                <textarea class="form-control" rows="5" placeholder="Cuéntanos en qué podemos ayudarte..." required></textarea>
                            </div>
                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-send w-100">
                                    ENVIAR MENSAJE <i class="bi bi-send ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Mapa Simulado -->
    <div class="container mb-5">
        <div class="rounded-5 overflow-hidden shadow-sm" style="height: 400px; background: #eee;">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3945.748375823469!2d-78.6781234254848!3d-8.523789191518386!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91ad4343e8000001%3A0x6b8f17781203085!2sNuevo%20Chao!5e0!3m2!1ses!2spe!4v1715456789012!5m2!1ses!2spe" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
        </div>
    </div>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            Swal.fire({
                title: '¡Mensaje Enviado!',
                text: 'Gracias por contactarnos. Nos comunicaremos contigo pronto.',
                icon: 'success',
                confirmButtonColor: '#ffc107',
                confirmButtonText: 'Genial'
            }).then(() => {
                window.location.href = '/';
            });
        });
    </script>
</body>
</html>
